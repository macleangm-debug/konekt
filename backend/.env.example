# Konekt Backend Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE
# ===========================================
MONGO_URL=mongodb://localhost:27017
DB_NAME=konekt_db

# ===========================================
# AUTHENTICATION
# ===========================================
JWT_SECRET=your-secure-random-string-min-32-chars

# ===========================================
# AI SERVICES (Emergent LLM Key)
# ===========================================
EMERGENT_LLM_KEY=your-emergent-llm-key

# ===========================================
# EMAIL SERVICE (Resend)
# ===========================================
RESEND_API_KEY=re_your_resend_api_key
SENDER_EMAIL=noreply@konekt.co.tz
ADMIN_EMAIL=info@konekt.co.tz

# ===========================================
# URLS
# ===========================================
FRONTEND_URL=https://konekt.co.tz
BACKEND_URL=https://api.konekt.co.tz

# ===========================================
# CORS (comma-separated origins)
# ===========================================
CORS_ORIGINS=https://konekt.co.tz,https://www.konekt.co.tz
