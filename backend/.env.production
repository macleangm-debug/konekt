# Konekt Backend Environment - PRODUCTION
# Copy to .env and fill with real values

# ===========================================
# DATABASE (internal Docker network)
# ===========================================
MONGO_URL=mongodb://mongodb:27017
DB_NAME=konekt_db

# ===========================================
# AUTHENTICATION (CHANGE THIS!)
# Generate with: openssl rand -base64 32
# ===========================================
JWT_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING

# ===========================================
# AI SERVICES
# Get from: Emergent Platform -> Profile -> Universal Key
# ===========================================
EMERGENT_LLM_KEY=your-emergent-llm-key-here

# ===========================================
# EMAIL SERVICE (Resend)
# Get from: https://resend.com/api-keys
# ===========================================
RESEND_API_KEY=re_your_resend_api_key_here
SENDER_EMAIL=noreply@konekt.co.tz
ADMIN_EMAIL=info@konekt.co.tz

# ===========================================
# URLS (must match your domain)
# ===========================================
FRONTEND_URL=https://konekt.co.tz
BACKEND_URL=https://konekt.co.tz

# ===========================================
# CORS (comma-separated, no spaces)
# ===========================================
CORS_ORIGINS=https://konekt.co.tz,https://www.konekt.co.tz
